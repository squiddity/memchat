{
  "name": "memchat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Memory-intensive chat agent experiments built on pi-coding-agent.",
  "keywords": ["pi-package"],
  "bin": {
    "memchat": "dist/index.js",
    "memchat-world-import": "dist/world-import-cli.js",
    "memchat-world-import-helper": "dist/world-import/command-router.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "world-import": "tsx src/world-import-cli.ts",
    "world-import-helper": "tsx src/world-import/command-router.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@tobilu/qmd": "2.5.3"
  },
  "pi": {
    "skills": ["./skills"]
  },
  "memchat": {
    "piPackages": []
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  }
}
