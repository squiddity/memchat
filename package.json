{
  "name": "memchat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Memory-intensive chat agent experiments built on pi-coding-agent.",
  "keywords": [
    "pi-package"
  ],
  "bin": {
    "memchat": "dist/index.js",
    "memchat-world-import": "dist/world-import-cli.js",
    "memchat-world-import-helper": "dist/world-import/command-router.js",
    "memchat-markdown-review": "dist/markdown-review-cli.js",
    "memchat-artifact-review": "dist/artifact-review-cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "world-import": "tsx src/world-import-cli.ts",
    "world-import-run": "bash ./scripts/world-import-run.sh",
    "world-import-helper": "tsx src/world-import/command-router.ts",
    "markdown-review": "tsx src/markdown-review-cli.ts",
    "artifact-review": "tsx src/artifact-review-cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:mem-import": "node --import tsx --test src/mem-import-tools.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@tobilu/qmd": "2.5.3",
    "mdts": "0.20.3",
    "vanilla-jsoneditor": "^3.12.0"
  },
  "pi": {
    "extensions": [
      "./extensions/mem-import-tools.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "memchat": {
    "piPackages": []
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  },
  "allowScripts": {
    "better-sqlite3@12.10.0": true,
    "esbuild@0.28.1": true,
    "node-llama-cpp@3.18.1": true,
    "tree-sitter-javascript@0.23.1": true,
    "tree-sitter-go@0.25.0": true,
    "tree-sitter-python@0.25.0": true,
    "tree-sitter-typescript@0.23.2": true,
    "tree-sitter-rust@0.24.0": true,
    "protobufjs@7.5.9": true,
    "@google/genai@1.52.0": true
  }
}
